@model GlowShop.Models.Product
@{
    ViewBag.Title = Model.Name;
}

<div class="container my-5 py-5">
    <div class="row g-5 align-items-center">

        <!-- Product Image Section -->
        <div class="col-md-5">
            <div class="product-image-container p-2 rounded-4 shadow-lg bg-white">
                <img src="@(Model.ImageUrl ?? "/Content/images/placeholder.jpg")"
                     class="img-fluid rounded-4" alt="@Model.Name"
                     style="width:100%; height: 500px; object-fit:cover;" />
            </div>
        </div>

        <!-- Product Info Section -->
        <div class="col-md-7 ps-md-5">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")" class="text-decoration-none text-muted">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Products")" class="text-decoration-none text-muted">Products</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Category?.Name</li>
                </ol>
            </nav>

            <h1 class="display-4 fw-bold mb-2 section-title" style="color:#1a0512;">@Model.Name</h1>
            
            <div class="d-flex align-items-center mb-4">
                <div class="rating-stars me-2">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="fas fa-star @(i <= (int)Model.Rating ? "text-warning" : "text-light-gray")"></i>
                    }
                </div>
                <span class="text-muted small">(@Model.Rating / 5.0)</span>
            </div>

            <div class="price-section mb-4">
                @if (Model.IsOnSale)
                {
                    <span class="text-muted text-decoration-line-through fs-4 me-2">$@Model.Price.ToString("F2")</span>
                    <span class="fs-1 fw-bold theme-text">$@Model.SalePrice.Value.ToString("F2")</span>
                    <span class="badge bg-danger ms-3 px-3 py-2 rounded-pill">SAVE @(((Model.Price - Model.SalePrice.Value)/Model.Price).ToString("P0"))</span>
                }
                else
                {
                    <span class="fs-1 fw-bold theme-text">$@Model.Price.ToString("F2")</span>
                }
            </div>

            <div class="description-section mb-5">
                <h5 class="fw-bold mb-3">About the Product</h5>
                <p class="text-secondary leading-relaxed" style="font-size: 1.1rem;">@Model.Description</p>
            </div>

            <div class="stock-status mb-4">
                @if (Model.Stock > 0)
                {
                    <p class="text-success fw-semibold"><i class="fas fa-check-circle me-2"></i>In Stock - Ready to Ship</p>
                }
                else
                {
                    <p class="text-danger fw-semibold"><i class="fas fa-times-circle me-2"></i>Out of Stock</p>
                }
            </div>

            <div class="action-buttons d-flex gap-3">
                <button class="btn btn-premium btn-lg px-5 py-3">ADD TO CART <i class="fas fa-shopping-bag ms-2"></i></button>
                <button class="btn btn-outline-dark btn-lg px-4 py-3"><i class="far fa-heart"></i></button>
            </div>
            
            <div class="mt-5 border-top pt-4">
                <div class="row text-center g-4">
                    <div class="col-4">
                        <i class="fas fa-truck text-muted mb-2"></i>
                        <p class="small mb-0">Free Shipping</p>
                    </div>
                    <div class="col-4">
                        <i class="fas fa-undo text-muted mb-2"></i>
                        <p class="small mb-0">30-Day Returns</p>
                    </div>
                    <div class="col-4">
                        <i class="fas fa-shield-alt text-muted mb-2"></i>
                        <p class="small mb-0">Secure Payment</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Products -->
    @if (ViewBag.Related != null)
    {
        var related = ViewBag.Related as List<GlowShop.Models.Product>;
        if (related.Count > 0)
        {
            <div class="mt-5 pt-5 border-top">
                <h2 class="section-title text-center mb-5">Complete Your Routine ✨</h2>
                <div class="row g-4">
                    @foreach (var r in related)
                    {
                        <div class="col-6 col-md-3">
                            <div class="card product-card border-0 shadow-sm h-100">
                                <div class="position-relative overflow-hidden">
                                    <img src="@(r.ImageUrl ?? "/Content/images/placeholder.jpg")"
                                         class="card-img-top" alt="@r.Name"
                                         style="height:250px; object-fit:cover;" />
                                    <a href="@Url.Action("Details", new { id = r.ProductId })" class="quick-view-overlay">
                                        <span>Quick View</span>
                                    </a>
                                </div>
                                <div class="card-body text-center">
                                    <h6 class="fw-bold mb-2">@r.Name</h6>
                                    <p class="theme-text fw-bold mb-0">$@r.DisplayPrice.ToString("F2")</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    .section-title {
        font-family: 'Playfair Display', serif;
    }

    .theme-text {
        color: #C2185B;
    }

    .text-light-gray {
        color: #e0e0e0;
    }

    .product-image-container {
        transition: transform 0.5s ease;
    }

    .product-image-container:hover {
        transform: scale(1.02);
    }

    .product-card {
        transition: all 0.3s ease;
        border-radius: 15px !important;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }

    .quick-view-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(136, 14, 79, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: 0.3s;
        text-decoration: none;
        color: white;
        font-weight: bold;
    }

    .product-card:hover .quick-view-overlay {
        opacity: 1;
    }

    .btn-premium {
        background: linear-gradient(45deg, #880E4F, #C2185B);
        color: white;
        border: none;
        border-radius: 8px;
        transition: all 0.3s ease;
        font-weight: 600;
        letter-spacing: 1px;
    }

    .btn-premium:hover {
        background: linear-gradient(45deg, #C2185B, #880E4F);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(194, 24, 91, 0.4);
    }

    .leading-relaxed {
        line-height: 1.8;
    }
</style>
```

