@model List<GlowShop.Models.Product>
@{
    ViewBag.Title = "Products";
    var categories = ViewBag.Categories as List<GlowShop.Models.Category>;
}

<div class="container my-5 pb-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold" style="color:#4a0d2c;">Our Beauty Collection 💄</h2>
        <div class="mx-auto mt-2" style="width: 80px; height: 4px; background: #C2185B; border-radius: 2px;"></div>
    </div>

    <!-- FILTERS -->
    <div class="card border-0 shadow-sm rounded-4 p-4 mb-5" style="background: white;">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold small text-uppercase" style="color:#880E4F;">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="fa fa-search"></i></span>
                    <input name="search" value="@ViewBag.Search" type="text"
                           placeholder="What are you looking for?"
                           class="form-control border-start-0" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small text-uppercase" style="color:#880E4F;">Category</label>
                <select name="categoryId" class="form-select">
                    <option value="">All Categories</option>
                    @if (categories != null)
                    {
                        foreach (var c in categories)
                        {
                            <option value="@c.CategoryId"
                                    @(ViewBag.CategoryId?.ToString() == c.CategoryId.ToString() ? "selected" : "")>
                                @c.Name
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small text-uppercase" style="color:#880E4F;">Sort By</label>
                <select name="sort" class="form-select">
                    <option value="">Name: A-Z</option>
                    <option value="price_asc" @(ViewBag.Sort == "price_asc" ? "selected" : "")>Price: Low to High</option>
                    <option value="price_desc" @(ViewBag.Sort == "price_desc" ? "selected" : "")>Price: High to Low</option>
                    <option value="rating" @(ViewBag.Sort == "rating" ? "selected" : "")>Top Rated</option>
                    <option value="newest" @(ViewBag.Sort == "newest" ? "selected" : "")>Newest</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-premium w-100 py-2 fw-bold">
                    Apply Filters
                </button>
            </div>
        </form>
    </div>

    <!-- PRODUCT GRID -->
    <div class="row g-4">
        @if (Model != null && Model.Count > 0)
        {
            foreach (var p in Model)
            {
                <div class="col-6 col-md-3">
                    <div class="card h-100 shadow-sm border-0 product-card">
                        <div class="position-relative">
                            @if (p.IsOnSale)
                            {
                                <span class="badge position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill shadow-sm" style="background:#C2185B;">SALE</span>
                            }
                            <img src="@(p.ImageUrl ?? "/Content/images/placeholder.jpg")"
                                 class="card-img-top" alt="@p.Name"
                                 style="height:250px; object-fit:cover;" />
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <span class="text-uppercase small fw-bold mb-1" style="color:#C2185B; letter-spacing: 1px;">@p.Category?.Name</span>
                            <h5 class="card-title fw-bold mb-1" style="color:#4a0d2c;">@p.Name</h5>
                            <div class="mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fa fa-star @(i <= Math.Floor(p.Rating) ? "text-warning" : "text-muted opacity-25") small"></i>
                                }
                            </div>
                            <div class="mt-auto pt-2">
                                <div class="mb-3">
                                    @if (p.IsOnSale)
                                    {
                                        <del class="text-muted small me-2">$@p.Price.ToString("F2")</del>
                                        <span class="fw-bold fs-5" style="color:#C2185B;">
                                            $@p.SalePrice.Value.ToString("F2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold fs-5" style="color:#C2185B;">
                                            $@p.Price.ToString("F2")
                                        </span>
                                    }
                                </div>
                                <a href="@Url.Action("Details", new { id = p.ProductId })"
                                   class="btn btn-premium w-100 py-2 fw-bold shadow-sm">
                                    View Product
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fa fa-search-minus display-1 text-muted opacity-25 mb-4"></i>
                <h4 class="text-muted">No products found. Try a different search! 🔍</h4>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary mt-3 rounded-pill px-4">Clear All Filters</a>
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-radius: 12px;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(136, 14, 79, 0.15) !important;
    }
    
    .btn-premium { background: #880E4F; color: white; border-radius: 20px; transition: all 0.3s; }
    .btn-premium:hover { background: #C2185B; color: white; transform: scale(1.05); }
    
    .form-control:focus, .form-select:focus {
        border-color: #ff80ab;
        box-shadow: 0 0 0 0.25rem rgba(255, 128, 171, 0.25);
    }
</style>
