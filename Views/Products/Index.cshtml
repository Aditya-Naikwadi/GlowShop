@model List<GlowShop.Models.Product>
@{
    ViewBag.Title = "Products";
    var categories = ViewBag.Categories as List<GlowShop.Models.Category>;
}

<div class="container my-5 pb-5">
    <div class="text-center mb-5 animate-on-scroll">
        <span class="text-uppercase tracking-widest small fw-bold" style="color: #C2185B;">Our Collection</span>
        <h2 class="display-5 fw-bold mt-2" style="color:#4a0d2c;">Exquisite Beauty 💄</h2>
        <div class="mx-auto mt-2" style="width: 50px; height: 3px; background: linear-gradient(to right, #C2185B, #880E4F); border-radius: 2px;"></div>
    </div>

    <!-- FILTERS -->
    <div class="glass-card p-4 mb-5 animate-on-scroll">
        <form method="get" class="row g-4 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-bold small text-uppercase tracking-wider" style="color:#880E4F;">Search</label>
                <div class="input-group premium-input-group">
                    <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="fa fa-search"></i></span>
                    <input name="search" value="@ViewBag.Search" type="text"
                           placeholder="Search essentials..."
                           class="form-control border-start-0 premium-input" />
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small text-uppercase tracking-wider" style="color:#880E4F;">Category</label>
                <select name="categoryId" class="form-select premium-select">
                    <option value="">All Categories</option>
                    @if (categories != null)
                    {
                        foreach (var c in categories)
                        {
                            <option value="@c.CategoryId"
                                    @(ViewBag.CategoryId?.ToString() == c.CategoryId.ToString() ? "selected" : "")>
                                @c.Name
                            </option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-bold small text-uppercase tracking-wider" style="color:#880E4F;">Sort By</label>
                <select name="sort" class="form-select premium-select">
                    <option value="">Name: A-Z</option>
                    <option value="price_asc" @(ViewBag.Sort == "price_asc" ? "selected" : "")>Price: Low to High</option>
                    <option value="price_desc" @(ViewBag.Sort == "price_desc" ? "selected" : "")>Price: High to Low</option>
                    <option value="rating" @(ViewBag.Sort == "rating" ? "selected" : "")>Top Rated</option>
                    <option value="newest" @(ViewBag.Sort == "newest" ? "selected" : "")>Newest</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-premium w-100 py-2 fw-bold shadow-sm">
                    Discover
                </button>
            </div>
        </form>
    </div>

    <!-- PRODUCT GRID -->
    <div class="row g-4">
        @if (Model != null && Model.Count > 0)
        {
            foreach (var p in Model)
            {
                <div class="col-6 col-md-3 animate-on-scroll">
                    <div class="card h-100 premium-product-card border-0">
                        <div class="img-wrapper position-relative overflow-hidden">
                            <img src="@(p.ImageUrl ?? "/Content/images/placeholder.jpg")"
                                 class="card-img-top" alt="@p.Name" />
                            <div class="card-overlay">
                                <a href="@Url.Action("Details", new { id = p.ProductId })" 
                                   class="btn btn-white-glass btn-sm rounded-pill px-4">View Details</a>
                            </div>
                            @if (p.IsOnSale)
                            {
                                <span class="badge sale-tag">SALE</span>
                            }
                        </div>
                        <div class="card-body p-4 text-center">
                            <span class="text-muted small mb-1 text-uppercase tracking-wider">@p.Category?.Name</span>
                            <h5 class="card-title fw-bold mb-2">@p.Name</h5>
                            <div class="mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fa fa-star @(i <= Math.Floor(p.Rating) ? "star-active" : "star-inactive") small"></i>
                                }
                            </div>
                            <div class="price-container">
                                @if (p.IsOnSale)
                                {
                                    <span class="text-muted text-decoration-line-through me-2">$@p.Price.ToString("F2")</span>
                                    <span class="fw-bold price-text">$@p.SalePrice.Value.ToString("F2")</span>
                                }
                                else
                                {
                                    <span class="fw-bold price-text">$@p.Price.ToString("F2")</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fa fa-search-minus display-1 text-muted opacity-25 mb-4"></i>
                <h4 class="text-muted">No products found. Try a different search! 🔍</h4>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary mt-3 rounded-pill px-4">Clear All Filters</a>
            </div>
        }
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap');

    body {
        font-family: 'Poppins', sans-serif;
        background-color: #fdfdfd;
    }

    .tracking-widest { letter-spacing: 0.2em; }
    
    .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .premium-input-group {
        border: 1px solid #eee;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.3s;
    }

    .premium-input-group:focus-within {
        border-color: #C2185B;
        box-shadow: 0 0 0 3px rgba(194, 24, 91, 0.1);
    }

    .premium-input, .premium-select {
        border: 1px solid #eee;
        border-radius: 12px !important;
        padding: 10px 15px;
        font-size: 0.95rem;
    }

    .premium-input:focus, .premium-select:focus {
        border-color: #C2185B;
        box-shadow: none;
    }

    .premium-product-card {
        border-radius: 15px;
        transition: all 0.4s ease;
        background: white;
        overflow: hidden;
    }

    .premium-product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    .img-wrapper img {
        height: 280px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .premium-product-card:hover .img-wrapper img {
        transform: scale(1.1);
    }

    .card-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(136, 14, 79, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .premium-product-card:hover .card-overlay {
        opacity: 1;
    }

    .btn-white-glass {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(5px);
        color: #880E4F;
        border: none;
        font-weight: 600;
    }

    .sale-tag {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #C2185B;
        color: white;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: bold;
    }

    .star-active { color: #FFD700; }
    .star-inactive { color: #e0e0e0; }
    .price-text { color: #C2185B; font-size: 1.2rem; }

    .btn-premium {
        background: linear-gradient(135deg, #880E4F 0%, #C2185B 100%);
        color: white;
        border: none;
        border-radius: 12px;
        transition: all 0.3s;
    }

    .btn-premium:hover {
        transform: scale(1.02);
        box-shadow: 0 5px 15px rgba(136, 14, 79, 0.3);
        color: white;
    }
</style>
