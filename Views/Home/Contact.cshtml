@model GlowShop.Models.ContactMessage
@{ 
    ViewBag.Title = "Contact Us"; 
}

<div class="contact-page py-5">
    <div class="container my-5">
        <div class="text-center mb-5">
            <h1 class="display-4 fw-bold section-title mb-3" style="color:#1a0512;">Let's Start a Conversation 💌</h1>
            <p class="lead text-muted mx-auto" style="max-width: 600px;">Have a question about our products or your glow journey? We're here to help you shine.</p>
        </div>

        <div class="row g-5 align-items-stretch">
            <!-- Contact Info Sidebar -->
            <div class="col-lg-4">
                <div class="contact-sidebar h-100 p-4 rounded-4 text-white shadow-lg" style="background: linear-gradient(135deg, #880E4F 0%, #4a0d2c 100%);">
                    <h3 class="fw-bold mb-4">Contact Information</h3>
                    <p class="mb-5 opacity-75">Fill out the form and our team will get back to you within 24 hours.</p>

                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle me-3"><i class="fas fa-phone-alt"></i></div>
                        <div>
                            <p class="mb-0 small opacity-75">Call Us</p>
                            <p class="mb-0 fw-bold">+1 800 GLOW-NOW</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="icon-circle me-3"><i class="fas fa-envelope"></i></div>
                        <div>
                            <p class="mb-0 small opacity-75">Email Us</p>
                            <p class="mb-0 fw-bold">hello@glowshop.com</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-center mb-5">
                        <div class="icon-circle me-3"><i class="fas fa-map-marker-alt"></i></div>
                        <div>
                            <p class="mb-0 small opacity-75">Visit Our Studio</p>
                            <p class="mb-0 fw-bold">5th Avenue, New York, NY</p>
                        </div>
                    </div>

                    <div class="social-links d-flex gap-3 mt-auto pt-5">
                        <a href="#" class="social-icon"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-8">
                <div class="card glass-card border-0 rounded-4 shadow-sm h-100">
                    <div class="card-body p-5">
                        @using (Html.BeginForm("Contact", "Home", FormMethod.Post, new { @class = "premium-form" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger rounded-3" })

                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        @Html.TextBoxFor(m => m.FullName, new { @class = "form-control custom-input", placeholder = "Jane Doe" })
                                        @Html.LabelFor(m => m.FullName, new { @class = "text-muted" })
                                        @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small" })
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-floating mb-3">
                                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control custom-input", placeholder = "you@email.com" })
                                        @Html.LabelFor(m => m.Email, new { @class = "text-muted" })
                                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating mb-3">
                                        @Html.TextBoxFor(m => m.Subject, new { @class = "form-control custom-input", placeholder = "Subject" })
                                        @Html.LabelFor(m => m.Subject, new { @class = "text-muted" })
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-floating mb-4">
                                        @Html.TextAreaFor(m => m.Message, new { @class = "form-control custom-input", style = "height: 150px", placeholder = "Message" })
                                        @Html.LabelFor(m => m.Message, new { @class = "text-muted" })
                                        @Html.ValidationMessageFor(m => m.Message, "", new { @class = "text-danger small" })
                                    </div>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-premium w-100 py-3 fw-bold">
                                        SEND MESSAGE <i class="fas fa-paper-plane ms-2"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .section-title {
        font-family: 'Playfair Display', serif;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.2);
    }

    .icon-circle {
        width: 45px;
        height: 45px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .social-icon {
        width: 40px;
        height: 40px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        transition: 0.3s;
    }

    .social-icon:hover {
        background: #C2185B;
        transform: translateY(-3px);
    }

    .custom-input {
        border: 1px solid #eee;
        border-radius: 10px !important;
        padding: 1rem 0.75rem;
    }

    .custom-input:focus {
        border-color: #C2185B;
        box-shadow: 0 0 0 0.25rem rgba(194, 24, 91, 0.1);
    }

    .btn-premium {
        background: linear-gradient(45deg, #880E4F, #C2185B);
        color: white;
        border: none;
        border-radius: 10px;
        transition: all 0.3s ease;
        letter-spacing: 1px;
    }

    .btn-premium:hover {
        background: linear-gradient(45deg, #C2185B, #880E4F);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(194, 24, 91, 0.4);
    }

    .contact-sidebar {
        display: flex;
        flex-direction: column;
    }
</style>

