@using System.Web.Mvc
@using System.Web.Mvc.Html
@inherits System.Web.Mvc.WebViewPage
@{
    ViewBag.Title = "Home";
    var products = ViewBag.FeaturedProducts as List<GlowShop.Models.Product>;
    var categories = ViewBag.Categories as List<GlowShop.Models.Category>;
}

<!-- HERO SECTION -->
<div class="hero-section text-center d-flex align-items-center justify-content-center">
    <div class="hero-overlay"></div>
    <div class="container position-relative py-5">
        <div class="glass-hero p-5 mx-auto" style="max-width: 800px;">
            <span class="badge rounded-pill px-3 py-2 mb-3" style="background: rgba(194, 24, 91, 0.2); color: #C2185B; border: 1px solid rgba(194, 24, 91, 0.3);">NEW COLLECTION 2024</span>
            <h1 class="display-2 fw-bold mb-3 text-white main-title">Unlock Your Natural Glow</h1>
            <p class="lead mb-4 fs-4 text-white-50">Discover a curated collection of premium beauty essentials <br class="d-none d-md-block"> designed to enhance your unique radiance.</p>
            <div class="d-flex gap-3 justify-content-center mt-4">
                <a href="@Url.Action("Index","Products")" class="btn btn-premium-white btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg">
                    <span>Explore Shop</span>
                </a>
                <a href="@Url.Action("About","Home")" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold rounded-pill hvr-grow">
                    Our Story
                </a>
            </div>
        </div>
    </div>
</div>

<!-- CATEGORIES -->
<div class="container my-5 py-5">
    <div class="text-center mb-5 animate-on-scroll">
        <span class="text-uppercase tracking-widest small fw-bold" style="color: #C2185B;">Curated Selection</span>
        <h2 class="display-5 fw-bold mt-2" style="color:#4a0d2c;">Shop by Category</h2>
        <div class="mx-auto mt-2" style="width: 50px; height: 3px; background: linear-gradient(to right, #C2185B, #880E4F); border-radius: 2px;"></div>
    </div>
    <div class="row g-4 justify-content-center">
        @if (categories != null)
        {
            foreach (var cat in categories)
            {
                <div class="col-6 col-md-3 animate-on-scroll">
                    <a href="@Url.Action("Index","Products", new { categoryId = cat.CategoryId })" class="text-decoration-none">
                        <div class="card category-card h-100 border-0 shadow-sm text-center">
                            <div class="card-body py-5">
                                <div class="cat-icon-container mb-4">
                                    <i class="fa fa-sparkles fs-1" style="color:#C2185B;"></i>
                                </div>
                                <h5 class="fw-bold mb-2" style="color:#4a0d2c;">@cat.Name</h5>
                                <span class="small text-muted text-uppercase tracking-wider">Discover More</span>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<!-- FEATURED PRODUCTS -->
<div class="bg-light-soft py-5">
    <div class="container my-5">
        <div class="text-center mb-5 animate-on-scroll">
            <span class="text-uppercase tracking-widest small fw-bold" style="color: #C2185B;">Most Wanted</span>
            <h2 class="display-5 fw-bold mt-2" style="color:#4a0d2c;">Featured Essentials ✨</h2>
            <div class="mx-auto mt-2" style="width: 50px; height: 3px; background: linear-gradient(to right, #C2185B, #880E4F); border-radius: 2px;"></div>
        </div>
        <div class="row g-4">
            @if (products != null)
            {
                foreach (var p in products)
                {
                    <div class="col-6 col-md-3 animate-on-scroll">
                        <div class="card h-100 premium-product-card">
                            <div class="img-wrapper position-relative overflow-hidden">
                                <img src="@(p.ImageUrl ?? "/Content/images/placeholder.jpg")"
                                     class="card-img-top" alt="@p.Name" />
                                <div class="card-overlay">
                                    <a href="@Url.Action("Details","Products", new { id = p.ProductId })" 
                                       class="btn btn-white-glass btn-sm rounded-pill px-4">Quick View</a>
                                </div>
                                @if (p.IsOnSale)
                                {
                                    <span class="badge sale-badge">SALE</span>
                                }
                            </div>
                            <div class="card-body p-4 text-center">
                                <p class="text-muted small mb-1 text-uppercase tracking-wider">Premium Care</p>
                                <h5 class="card-title fw-bold mb-2">@p.Name</h5>
                                <div class="mb-3">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa fa-star @(i <= Math.Floor(p.Rating) ? "star-active" : "star-inactive") small"></i>
                                    }
                                </div>
                                <div class="price-container">
                                    @if (p.IsOnSale)
                                    {
                                        <span class="text-muted text-decoration-line-through me-2">$@p.Price.ToString("F2")</span>
                                        <span class="fw-bold price-text">$@p.SalePrice.Value.ToString("F2")</span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold price-text">$@p.Price.ToString("F2")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;500;600&display=swap');

    body {
        font-family: 'Poppins', sans-serif;
    }

    .main-title {
        font-family: 'Playfair Display', serif;
    }

    .hero-section {
        background: url('/Content/images/hero-bg.jpg') center/cover no-repeat;
        min-height: 85vh;
        position: relative;
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle, rgba(74, 13, 44, 0.4) 0%, rgba(136, 14, 79, 0.6) 100%);
    }

    .glass-hero {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 30px;
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
        animation: fadeInDown 1s ease-out;
    }

    .btn-premium-white {
        background: white;
        color: #880E4F;
        border: none;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .btn-premium-white:hover {
        background: #f8f8f8;
        transform: scale(1.05) translateY(-3px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
        color: #C2185B;
    }

    .tracking-widest { letter-spacing: 0.2em; }
    
    .category-card {
        border-radius: 20px;
        transition: all 0.4s ease;
        background: white;
        position: relative;
        overflow: hidden;
    }

    .category-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(136, 14, 79, 0.1) !important;
    }

    .cat-icon-container {
        width: 80px;
        height: 80px;
        background: #fff5f8;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
        transition: all 0.4s ease;
    }

    .category-card:hover .cat-icon-container {
        background: #C2185B;
        transform: rotate(15deg);
    }

    .category-card:hover .fa-sparkles {
        color: white !important;
    }

    .premium-product-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.4s ease;
        background: white;
    }

    .premium-product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    .img-wrapper img {
        height: 300px;
        width: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
    }

    .premium-product-card:hover .img-wrapper img {
        transform: scale(1.1);
    }

    .card-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(136, 14, 79, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .premium-product-card:hover .card-overlay {
        opacity: 1;
    }

    .btn-white-glass {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(5px);
        color: #880E4F;
        border: none;
        font-weight: 600;
        transition: all 0.3s;
    }

    .btn-white-glass:hover {
        background: white;
        transform: scale(1.1);
    }

    .sale-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: #C2185B;
        padding: 8px 15px;
        font-weight: bold;
        border-radius: 50px;
    }

    .star-active { color: #FFD700; }
    .star-inactive { color: #e0e0e0; }
    .price-text { color: #C2185B; font-size: 1.25rem; }

    @@keyframes fadeInDown {
        from { opacity: 0; transform: translateY(-30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .bg-light-soft { background-color: #fbfbfb; }
</style>
