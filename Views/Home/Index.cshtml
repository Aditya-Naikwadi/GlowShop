@using System.Web.Mvc
@using System.Web.Mvc.Html
@inherits System.Web.Mvc.WebViewPage
@{
    ViewBag.Title = "Home";
    var products = ViewBag.FeaturedProducts as List<GlowShop.Models.Product>;
    var categories = ViewBag.Categories as List<GlowShop.Models.Category>;
}

<!-- HERO SECTION -->
<div class="hero-section text-center d-flex align-items-center">
    <div class="container py-5">
        <h1 class="display-2 fw-bold mb-3 text-white">Unlock Your Natural Glow</h1>
        <p class="lead mb-4 fs-4 text-white-50">Discover a curated collection of premium beauty essentials <br class="d-none d-md-block"> designed to enhance your unique radiance.</p>
        <div class="d-flex gap-3 justify-content-center">
            <a href="@Url.Action("Index","Products")" class="btn btn-light btn-lg px-4 py-3 fw-bold rounded-pill shadow-sm" style="color:#880E4F;">
                Explore Shop
            </a>
            <a href="@Url.Action("About","Home")" class="btn btn-outline-light btn-lg px-4 py-3 fw-bold rounded-pill">
                Our Story
            </a>
        </div>
    </div>
</div>

<!-- CATEGORIES -->
<div class="container my-5 py-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold" style="color:#4a0d2c;">Shop by Category</h2>
        <div class="mx-auto mt-2" style="width: 60px; height: 4px; background: #C2185B; border-radius: 2px;"></div>
    </div>
    <div class="row g-4 justify-content-center">
        @if (categories != null)
        {
            foreach (var cat in categories)
            {
                <div class="col-6 col-md-3">
                    <a href="@Url.Action("Index","Products", new { categoryId = cat.CategoryId })" class="text-decoration-none">
                        <div class="card category-card h-100 border-0 shadow-sm overflow-hidden text-center">
                            <div class="card-body py-4">
                                <div class="cat-icon mb-3">
                                    <i class="fa fa-sparkles fs-1" style="color:#C2185B;"></i>
                                </div>
                                <h5 class="fw-bold mb-0" style="color:#4a0d2c;">@cat.Name</h5>
                            </div>
                        </div>
                    </a>
                </div>
            }
        }
    </div>
</div>

<!-- FEATURED PRODUCTS -->
<div class="container my-5 py-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold" style="color:#4a0d2c;">Featured Products ✨</h2>
        <div class="mx-auto mt-2" style="width: 60px; height: 4px; background: #C2185B; border-radius: 2px;"></div>
    </div>
    <div class="row g-4">
        @if (products != null)
        {
            foreach (var p in products)
            {
                <div class="col-6 col-md-3">
                    <div class="card h-100 shadow-sm product-card border-0">
                        <div class="position-relative overflow-hidden">
                            <img src="@(p.ImageUrl ?? "/Content/images/placeholder.jpg")"
                                 class="card-img-top" alt="@p.Name"
                                 style="height:250px; object-fit:cover;" />
                            @if (p.IsOnSale)
                            {
                                <span class="badge position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill" 
                                      style="background:#C2185B;">SALE</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column p-4">
                            <h5 class="card-title fw-bold mb-2" style="color:#4a0d2c;">@p.Name</h5>
                            <div class="mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fa fa-star @(i <= Math.Floor(p.Rating) ? "text-warning" : "text-muted opacity-25") small"></i>
                                }
                            </div>
                            <div class="mt-auto">
                                <div class="d-flex align-items-center mb-3">
                                    @if (p.IsOnSale)
                                    {
                                        <span class="text-muted text-decoration-line-through me-2 small">
                                            $@p.Price.ToString("F2")
                                        </span>
                                        <span class="fw-bold fs-5" style="color:#C2185B;">
                                            $@p.SalePrice.Value.ToString("F2")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="fw-bold fs-5" style="color:#C2185B;">
                                            $@p.Price.ToString("F2")
                                        </span>
                                    }
                                </div>
                                <a href="@Url.Action("Details","Products", new { id = p.ProductId })"
                                   class="btn btn-premium w-100 py-2 fw-bold shadow-sm">
                                    View Product
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(rgba(74, 13, 44, 0.7), rgba(136, 14, 79, 0.7)), 
                    url('/Content/images/hero-bg.jpg') center/cover;
        min-height: 500px;
        color: white;
    }

    .product-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border-radius: 12px;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 35px rgba(136, 14, 79, 0.15) !important;
    }

    .category-card {
        transition: all 0.3s ease;
        background: #ffffff;
        border-radius: 15px;
    }

    .category-card:hover {
        transform: scale(1.03);
        background: #fff5f8;
    }
    
    .price-text { color: #C2185B; font-size: 1.1rem; }
    .btn-premium { background: #880E4F; color: white; border-radius: 20px; transition: all 0.3s; }
    .btn-premium:hover { background: #C2185B; color: white; transform: scale(1.05); }
</style>
