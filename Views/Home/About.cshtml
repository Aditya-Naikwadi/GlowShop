@inherits System.Web.Mvc.WebViewPage
@{ ViewBag.Title = "About Us"; }

<!-- HERO -->
<div style="background:linear-gradient(135deg,#880E4F,#C2185B);
            color:white; padding:70px 0;" class="text-center">
    <div class="container">
        <h1 class="display-5 fw-bold">Our Story 🌸</h1>
        <p class="lead">Beauty that empowers, products you can trust</p>
    </div>
</div>

<!-- MISSION -->
<div class="container my-5 text-center" style="max-width:750px;">
    <h2 class="fw-bold mb-3" style="color:#880E4F;">Our Mission</h2>
    <p class="lead text-muted">
        At GlowShop, we believe every person deserves to feel confident and beautiful.
        Founded in 2020, we curate the finest beauty products — from skincare essentials
        to statement makeup — all cruelty-free and ethically sourced.
    </p>
</div>

<!-- VALUES -->
<div class="container my-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="p-4 rounded-4 h-100" style="background:#FFF0F6;">
                <div style="font-size:3rem;">🌿</div>
                <h5 class="fw-bold mt-2" style="color:#880E4F;">Cruelty-Free</h5>
                <p class="text-muted">Every product we carry is cruelty-free and ethically produced.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4 h-100" style="background:#FFF0F6;">
                <div style="font-size:3rem;">💎</div>
                <h5 class="fw-bold mt-2" style="color:#880E4F;">Premium Quality</h5>
                <p class="text-muted">Only the highest quality formulations make it to our shelves.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4 rounded-4 h-100" style="background:#FFF0F6;">
                <div style="font-size:3rem;">🚀</div>
                <h5 class="fw-bold mt-2" style="color:#880E4F;">Fast Delivery</h5>
                <p class="text-muted">Orders ship within 24 hours with free delivery over $50.</p>
            </div>
        </div>
    </div>
</div>
