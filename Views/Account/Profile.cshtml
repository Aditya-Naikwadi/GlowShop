@model GlowShop.Models.ApplicationUser
@{ ViewBag.Title = "My Profile"; }

<div class="container my-5" style="max-width:600px;">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header text-white text-center py-4"
             style="background:linear-gradient(135deg,#880E4F,#C2185B); border-radius:16px 16px 0 0;">
            <div class="rounded-circle bg-white d-inline-flex align-items-center
                  justify-content-center mb-3"
                 style="width:80px;height:80px; font-size:2rem;">👤</div>
            <h3 class="mb-0">@Model.FullName</h3>
            <small>@Model.Email</small>
        </div>
        <div class="card-body p-5">
            <div class="row g-3">
                <div class="col-6">
                    <label class="fw-semibold text-muted small">FIRST NAME</label>
                    <p class="fs-5">@(Model.FirstName ?? "—")</p>
                </div>
                <div class="col-6">
                    <label class="fw-semibold text-muted small">LAST NAME</label>
                    <p class="fs-5">@(Model.LastName ?? "—")</p>
                </div>
                <div class="col-12">
                    <label class="fw-semibold text-muted small">EMAIL</label>
                    <p class="fs-5">@Model.Email</p>
                </div>
                <div class="col-12">
                    <label class="fw-semibold text-muted small">MEMBER SINCE</label>
                    <p class="fs-5">@Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
                </div>
            </div>
            <hr />
            <div class="d-flex gap-2">
                <a href="@Url.Action("Index","Products")"
                   class="btn text-white" style="background:#C2185B;">
                    🛍️ Shop Now
                </a>
                @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">Logout</button>
                }
            </div>
        </div>
    </div>
</div>
